{
  "name": "turtleback-sanctuary",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@11.12.0",
  "type": "module",
  "description": "A calming first-person exploration game set in a village on the back of a colossal sea turtle.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.2",
    "@react-three/drei": "^10.7.6",
    "@react-three/fiber": "^9.3.0",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.1.0",
    "postprocessing": "^6.37.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.182.0",
    "three-stdlib": "^2.36.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.4"
  }
}
